{
  "ConnectionStrings": {
    "DevBoardDb": "Server=localhost;Database=DevBoardDb;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "GitHub": {
    "WebhookSecret": "set-local-webhook-secret"
  },
  "GitHubOAuth": {
    "ClientId": "set-local-github-client-id",
    "ClientSecret": "set-local-github-client-secret",
    "BackendCallbackUrl": "http://localhost:5067/api/auth/github/callback",
    "FrontendSuccessUrl": "http://localhost:4200/auth/github/callback",
    "FrontendErrorUrl": "http://localhost:4200/auth/login?oauth=error"
  },
  "GitHubApp": {
    "AppId": "set-local-github-app-id",
    "PrivateKey": "set-local-github-app-private-key",
    "InstallUrl": "https://github.com/apps/TU_APP/installations/new",
    "StateSecret": "set-local-github-app-state-secret"
  },
  "Frontend": {
    "BaseUrl": "http://localhost:4200"
  },
  "Jwt": {
    "Issuer": "DevBoard.Api",
    "Audience": "DevBoard.Frontend",
    "Key": "set-local-jwt-key",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
